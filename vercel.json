{
  "version": 2,
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://banking-support-chatbot-backend.onrender.com/api/:path*"
    },
    {
      "source": "/static/:path*",
      "destination": "/frontend/:path*"
    },
    {
      "source": "/",
      "destination": "/frontend/index.html"
    },
    {
      "source": "/((?!frontend|api|static).*)",
      "destination": "/frontend/$1"
    }
  ]
}
