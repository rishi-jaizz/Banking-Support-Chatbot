# LLM API Keys (Set at least one depending on LLM_PROVIDER)
GOOGLE_API_KEY=your_google_api_key_here
GROQ_API_KEY=your_groq_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Application Settings
APP_ENV=development # "development" or "production"
APP_HOST=0.0.0.0
APP_PORT=10000

# CORS Settings (Comma-separated list of allowed origins, or "*" to allow all)
CORS_ORIGINS=*

# RAG Settings
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K_RESULTS=5
COLLECTION_NAME=banking_knowledge
MIN_RELEVANCE_THRESHOLD=0.28

# LLM Configs
LLM_PROVIDER=gemini # "gemini", "groq", or "openai"
EMBEDDING_MODEL=all-MiniLM-L6-v2
LLM_MODEL=gemini-2.0-flash # e.g., "llama-3.3-70b-versatile" for Groq, "gpt-4o-mini" for OpenAI
LLM_TIMEOUT=20.0
LLM_MAX_RETRIES=3

# Paths (Defaults are local relative paths, override in production)
# DATA_DIR=/data/banking_knowledge
# CHROMA_PERSIST_DIR=/data/chroma_db
# SESSIONS_DIR=/data/sessions
# METADATA_PATH=/data/documents_metadata.json
